<?xml version="1.0" encoding="utf-8"?><Database Name="GamesDataBase" Class="ReplayDataDataContext" xmlns="http://schemas.microsoft.com/linqtosql/dbml/2007">
  <Connection Mode="AppSettings" ConnectionString="Data Source=(LocalDB)\MSSQLLocalDB;AttachDbFilename=|DataDirectory|\Data\DB\GamesDataBase.mdf;Integrated Security=True" SettingsObjectName="CheckerZ.Properties.Settings" SettingsPropertyName="GamesDataBaseConnectionString" Provider="System.Data.SqlClient" />
  <Table Name="dbo.GameTable" Member="GameTables">
    <Type Name="GameTable">
      <Column Name="GameID" Type="System.Int32" DbType="Int NOT NULL IDENTITY" IsPrimaryKey="true" IsDbGenerated="true" CanBeNull="false" />
