      <Association Name="GameTable_GameMoveTable" Member="GameTable" ThisKey="GameID" OtherKey="GameID" Type="GameTable" IsForeignKey="true" DeleteRule="CASCADE" DeleteOnNull="true" />
    </Type>
  </Table>
