  <Table Name="dbo.GameMoveTable" Member="GameMoveTables">
    <Type Name="GameMoveTable">
      <Column Name="MoveID" Type="System.Int32" DbType="Int NOT NULL IDENTITY" IsPrimaryKey="true" IsDbGenerated="true" CanBeNull="false" />
